<!doctype html>
<html lang="<%= config.language %>">
<head>
  <meta charset="utf-8">
  <title><%= page.title %> · <%= config.title %></title>
</head>
<body>
  <article>
    <h1><%= page.title %></h1>
    <%- page.content %>
    <% if (page.tags && page.tags.length) { %>
      <ul class="tags">
        <% page.tags.each(function(tag) { %>
          <li><a href="<%- url_for(tag.path) %>"><%= tag.name %></a></li>
        <% }); %>
      </ul>
    <% } %>
  </article>
</body>
</html>
